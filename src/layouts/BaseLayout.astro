---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "melisapo's portfolio" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-petal/25 mx-auto max-w-[1200px]">
    <slot />
  </body>
</html>
