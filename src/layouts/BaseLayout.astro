---
import "../styles/global.css";

interface Props {
  title?: string;
  className?: string;
}

const { title = "melisapo's portfolio", className } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class={className}>
    <slot />
  </body>
</html>
