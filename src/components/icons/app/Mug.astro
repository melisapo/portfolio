---
interface Props {
  size: string;
}

const { size = "128" } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  xmlns:xlink="http://www.w3.org/1999/xlink"
  width={size}
  height={size}
  viewBox="0 0 128 128"
>
  <image
    xlink:href="data:image/png;base64,"
    x="0"
    y="0"
    width="128"
    height="128"
    class="cust-pointer"
  />
</svg>
