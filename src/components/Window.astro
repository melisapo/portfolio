---
interface Props {
  title: string;
  id: string;
}

const { title, id } = Astro.props;
---

<div id={id} class="window pixel-border bg-cream hidden h-[520px] w-[800px]">
  <!-- barra superior -->
  <div
    class="titlebar bg-lime/60 border-wine flex items-center justify-between border-b-3 border-dashed px-4 py-2"
  >
    <span class="text-wine font-mono text-4xl">{title}</span>
    <button
      class="close-btn cursor-pointer hover:scale-110 active:scale-90"
      data-target={id}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        xmlns:xlink="http://www.w3.org/1999/xlink"
        width="32"
        height="32"
        viewBox="0 0 64 64"
      >
        <image
          xlink:href="data:image/png;base64,"
          x="0"
          y="0"
          width="64"
          height="64"
        />
      </svg>
    </button>
  </div>
  <div class="">
    <div class="bg-lime/60 border-wine/20 h-[4px] w-full border-b"></div>
    <slot />
  </div>
</div>
