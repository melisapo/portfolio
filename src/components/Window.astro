---
import close from "@/assets/decorations/close.png";

interface Props {
  title: string;
  id: string;
}

const { title, id } = Astro.props;
---

<div
  id={id}
  class="window pixel-border-nm bg-cream hidden w-full overflow-hidden xl:w-[750px]"
>
  <!-- barra superior -->
  <div
    class="titlebar bg-lime/60 border-wine flex items-center justify-between border-b-3 border-dashed px-2 py-1 md:px-4 md:py-2"
  >
    <span class="text-wine font-mono text-lg md:text-2xl xl:text-4xl"
      >{title}</span
    >
    <button
      class="close-btn cursor-pointer hover:scale-110 active:scale-90"
      data-target={id}
    >
      <img src={close.src} class="w-6 cursor-pointer md:w-10" alt="close-btn" />
    </button>
  </div>
  <div>
    <div class="bg-lime/60 border-wine/20 h-[4px] w-full border-b"></div>
    <div class="grid place-items-center">
      <slot />
    </div>
  </div>
</div>
