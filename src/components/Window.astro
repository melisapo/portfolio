---
interface Props {
  title: string;
  id: string;
}

const { title, id } = Astro.props;
---

<div
  id={id}
  class="window pixel-border-nm bg-cream hidden w-full overflow-hidden xl:w-[800px]"
>
  <!-- barra superior -->
  <div
    class="titlebar bg-lime/60 border-wine flex items-center justify-between border-b-3 border-dashed px-3 py-1.5 md:px-4 md:py-2"
  >
    <span class="text-wine font-mono text-3xl md:text-4xl">{title}</span>
    <button
      class="close-btn cursor-pointer hover:scale-110 active:scale-90"
      data-target={id}
    >
      <img
        src="/decorations/close.png"
        class="w-8 cursor-pointer md:w-12"
        alt="close-btn"
      />
    </button>
  </div>
  <div>
    <div class="bg-lime/60 border-wine/20 h-[4px] w-full border-b"></div>
    <div class="grid place-items-center">
      <slot />
    </div>
  </div>
</div>
