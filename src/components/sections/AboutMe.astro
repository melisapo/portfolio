---
import me from "@/assets/me.webp";

import Button from "@/components/ui/Button.astro";
---

<div
  class="text-wine font-display flex w-full flex-col items-center gap-2 p-3 sm:p-6 md:gap-6"
>
  <div
    class="flex flex-col-reverse items-center gap-4 sm:flex-row sm:gap-20 landscape:flex-row"
  >
    <div class="flex flex-col items-center gap-2 sm:items-start md:gap-4">
      <h2 class="font-mono text-3xl md:text-6xl">Hi, my name is Melissa!</h2>
      <p class="pb-1 font-semibold md:text-2xl">
        And I am a <span
          class="text-petal border-petal border-b-2 border-dashed"
          >Software Developer</span
        >.
      </p>
    </div>
    <img src={me.src} alt="profile pic" class="w-30 md:w-50" />
  </div>
  <div
    class="pixel-bg-sheet pixel-border max-w-[650px] justify-center p-1.5 pl-3 text-sm font-medium md:pl-8 md:text-xl"
  >
    <p>
      I am currently in my third year of Computer Engineering at the University
      of Matanzas, Cuba. I am consistently driven to learn, share my knowledge,
      and develop tools that may prove useful to fellow developers. I believe
      that good software is simple, well-documented, and solves real problems
      without unnecessary complexity.
    </p>
    <p>
      In my free time, I enjoy creating pixel art, crafting handmade items, and
      baking sweet treats. <span class="font-symbols"></span>
    </p>
  </div>
  <Button> Download CV </Button>
</div>
