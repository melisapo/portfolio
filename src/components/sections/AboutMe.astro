---
import Button from "../ui/Button.astro";
---

<div class="text-wine font-display flex flex-col items-center gap-6 p-6">
  <div class="flex items-center gap-20">
    <div class="flex flex-col gap-4">
      <h2 class="font-mono text-6xl">Hola, me llamo Melissa!</h2>
      <p class="text-2xl font-semibold">
        Y soy <span class="text-petal">Desarrolladora de Software</span>.
      </p>
    </div>
    <div class="relative flex items-center justify-center">
      <img src="./me.png" alt="profile pic" class="inset-0 h-50 w-50" />
      <svg
        xmlns="http://www.w3.org/2000/svg"
        xmlns:xlink="http://www.w3.org/1999/xlink"
        width="150"
        height="150"
        viewBox="0 0 256 256"
        class="absolute"
      >
        <image
          xlink:href="data:image/png;base64,"
          x="0"
          y="0"
          width="256"
          height="256"
        />
      </svg>
    </div>
  </div>
  <p
    class="pixel-bg-sheet pixel-border mb-10 flex max-w-[650px] justify-center p-6 pl-16 text-xl font-medium"
  >
    Actualmente estoy cursando 3er ano de Ingenieria Informatica en la
    Universidad de Matanzas, Cuba.
  </p>
  <div class="flex items-center gap-20">
    <Button id="dw-cv" color="petal">
      <p class="cust-pointer">Descargar CV</p>
    </Button>
    <Button id="contact" color="lime">
      <p class="cust-pointer">Contactame</p>
    </Button>
  </div>
</div>
