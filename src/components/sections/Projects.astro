---
import ProjectCard from "../ui/ProjectCard.astro";

const projects = [
  {
    title: "Pixel Avatar",
    description:
      "It is a free and simple microservice to create avatars based on any text input. Its main purpose is to serve as a fallback image or default avatar in web applications, especially useful when a user hasn't uploaded their own photo.",
    image: "/project-shots/pixel-avatar.webp",
    techs: ["C#", "ASP.NET Core", "WebComponents", "TailwindCSS"],
    projectUrl: "https://pixelavatar.onrender.com",
    repoUrl: "https://github.com/melisapo/pixel-avatar-api",
  },
  {
    title: "FleaMarket",
    description:
      "It is a marketplace-style web application designed to facilitate the buying and selling of second-hand items between individuals. Its main objective is to centralize listings and enable advanced searches by categories and prices.",
    image: "/project-shots/flea.webp",
    techs: ["C#", "ASP.NET", "MVC", "PostgreSQL"],
    repoUrl: "https://github.com/melisapo/flea",
  },
  {
    title: "Jerry's Pixel Icons",
    description:
      "A Visual Studio Code extension that replaces file explorer icons with a pixel-art style set, adding a fun and retro touch to your editor. It includes support for the most common file types and folders, with over 1k installations and growing.",
    image: "/project-shots/icons.webp",
    techs: ["Aseprite", "JavaScript"],
    projectUrl:
      "https://marketplace.visualstudio.com/items?itemName=MelissaGutierrez.jerrys-pixel-icons&ssr=false#overview",
    repoUrl: "https://github.com/wolfsouldev/jerrys-pixel-icons",
  },
];
---

<div class="jutify-between flex w-full flex-col items-center p-4 md:p-8">
  <div>
    {
      projects.map((project, i) => (
        <div class={`project-slide ${i !== 0 ? "hidden" : ""}`} data-index={i}>
          <ProjectCard {...project} />
        </div>
      ))
    }
  </div>

  <div class="flex w-full items-end justify-between pt-6">
    <button
      id="prev-btn"
      class="cursor-pointer hover:scale-110 active:scale-90"
    >
      <img
        src="decorations/project-arrow.png"
        alt=""
        class="w-12 xl:w-16"
        role="button"
      />
    </button>
    <span id="counter" class="text-wine/90 font-mono text-xl md:text-3xl"
      >1 / {projects.length}</span
    >
    <button
      id="next-btn"
      class="cursor-pointer hover:scale-110 active:scale-90"
    >
      <img
        alt="→"
        src="decorations/project-arrow.png"
        class="w-12 rotate-180 xl:w-16"
        role="button"
      />
    </button>
  </div>
</div>

<script>
  const slides = document.querySelectorAll(".project-slide");
  const counter = document.getElementById("counter");
  let current = 0;

  function goTo(index: number) {
    slides[current].classList.add("hidden");
    current = (index + slides.length) % slides.length;
    slides[current].classList.remove("hidden");
    if (counter) counter.textContent = `${current + 1} / ${slides.length}`;
  }

  document
    .getElementById("prev-btn")
    ?.addEventListener("click", () => goTo(current - 1));
  document
    .getElementById("next-btn")
    ?.addEventListener("click", () => goTo(current + 1));
</script>
