---
import ProjectCard from "../ui/ProjectCard.astro";

const projects = [
  {
    title: "Pixel Avatar",
    description:
      "Es un microservicio gratuito y simple para crear avatares basados en cualquier entrada de texto. Su principal objetivo es servir como imagen de respaldo o avatar predeterminado en aplicaciones web, especialmente útil cuando un usuario no ha subido su propia foto.",
    image: "/project-shots/pixel-avatar.webp",
    techs: ["C#", "ASP.NET Core", "Web Components", "TailwindCSS"],
    projectUrl: "https://pixelavatar.onrender.com",
    repoUrl: "https://github.com/melisapo/pixel-avatar-api",
  },
  {
    title: "FleaMarket",
    description:
      "Es una aplicación web tipo marketplace, diseñada para facilitar la compra-venta de artículos de segunda mano entre particulares, con un enfoque en el trato directo. Su principal objetivo es centralizar ofertas y permitir búsquedas avanzadas por categorías y precios, evitando que los anuncios se pierdan en redes sociales, sirviendo como alternativa local a plataformas genéricas.",
    image: "/project-shots/flea.webp",
    techs: ["C#", "ASP.NET MVC", "PostgreSQL"],
    repoUrl: "https://github.com/melisapo/flea",
  },
  {
    title: "Jerry's Pixel Icons",
    description:
      "Extensión para Visual Studio Code que reemplaza los iconos del explorador de archivos por un set en estilo pixel-art, aportando un toque divertido y retro a tu editor. Actualmente con mas de 1k instalaciones.",
    image: "/projects/project3.webp",
    techs: ["Aseprite", "JavaScript"],
    projectUrl:
      "https://marketplace.visualstudio.com/items?itemName=MelissaGutierrez.jerrys-pixel-icons&ssr=false#overview",
    repoUrl: "https://github.com/wolfsouldev/jerrys-pixel-icons",
  },
];
---

<div class="jutify-between flex w-full flex-col items-center px-8 pb-8">
  <div>
    {
      projects.map((project, i) => (
        <div class={`project-slide ${i !== 0 ? "hidden" : ""}`} data-index={i}>
          <ProjectCard {...project} />
        </div>
      ))
    }
  </div>

  <div class="flex w-full items-end justify-between">
    <button
      id="prev-btn"
      class="cursor-pointer hover:scale-110 active:scale-90"
    >
      <img
        src="decorations/project-arrow.png"
        alt=""
        class="h-16 w-16"
        role="button"
      />
    </button>
    <span id="counter" class="text-wine/90 font-mono text-3xl"
      >1 / {projects.length}</span
    >
    <button
      id="next-btn"
      class="cursor-pointer hover:scale-110 active:scale-90"
    >
      <img
        alt="→"
        src="decorations/project-arrow.png"
        class="h-16 w-16 rotate-180"
        role="button"
      />
    </button>
  </div>
</div>

<script>
  const slides = document.querySelectorAll(".project-slide");
  const counter = document.getElementById("counter");
  let current = 0;

  function goTo(index: number) {
    slides[current].classList.add("hidden");
    current = (index + slides.length) % slides.length;
    slides[current].classList.remove("hidden");
    if (counter) counter.textContent = `${current + 1} / ${slides.length}`;
  }

  document
    .getElementById("prev-btn")
    ?.addEventListener("click", () => goTo(current - 1));
  document
    .getElementById("next-btn")
    ?.addEventListener("click", () => goTo(current + 1));
</script>
