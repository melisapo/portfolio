---
import AppIcon from "@/components/AppIcon.astro";
import Window from "@/components/Window.astro";
import AboutMe from "@/components/sections/AboutMe.astro";
import Projects from "@/components/sections/Projects.astro";
import Skills from "@/components/sections/Skills.astro";
import Contact from "@/components/sections/Contact.astro";
import Clock from "@/components/ui/Clock.astro";

import berry from "@/assets/app/berry.png";
import btn from "@/assets/app/btn.png";
import mug from "@/assets/app/mug.png";
import bug from "@/assets/app/bug.png";
import gif from "@/assets/hola.gif";
---

<div
  class="desktop center grid h-dvh w-dvw place-items-center overflow-hidden px-2 pb-10 2xl:p-10"
>
  <div class="flex flex-col items-center justify-center 2xl:flex-row">
    <!-- ventanas -->
    <div class="order-1 mx-auto my-auto w-full p-4 2xl:order-2">
      <Clock />
      <Window id="window-about" title="about me.">
        <AboutMe />
      </Window>

      <Window id="window-projects" title="my projects and experience.">
        <Projects />
      </Window>

      <Window id="window-skills" title="languages and technologies.">
        <Skills />
      </Window>

      <Window id="window-contact" title="contact me.">
        <Contact />
      </Window>
    </div>

    <!-- iconos -->
    <div
      class="icons fixed bottom-0 order-2 grid grid-cols-4 gap-6 pb-2 md:bottom-10 2xl:top-20 2xl:bottom-20 2xl:left-30 2xl:order-1 2xl:grid-cols-1 2xl:gap-6"
    >
      <AppIcon label="about me" target="window-about">
        <img
          src={berry.src}
          alt=""
          class="w-16 cursor-pointer md:w-20 2xl:w-28"
        />
      </AppIcon>

      <AppIcon label="projects" target="window-projects">
        <img
          src={btn.src}
          alt=""
          class="w-16 cursor-pointer md:w-20 2xl:w-28"
        />
      </AppIcon>

      <AppIcon label="skills" target="window-skills">
        <img
          src={mug.src}
          alt=""
          class="w-16 cursor-pointer md:w-20 2xl:w-28"
        />
      </AppIcon>

      <AppIcon label="contact" target="window-contact">
        <img
          src={bug.src}
          alt=""
          class="w-16 cursor-pointer md:w-20 2xl:w-28"
        />
      </AppIcon>
    </div>
  </div>

  <script>
    document.getElementById("window-about")?.classList.remove("hidden");
    const allWindows = () => document.querySelectorAll(".window");
    document.querySelectorAll(".app-icon").forEach((icon) => {
      icon.addEventListener("click", () => {
        const target = icon.getAttribute("data-target");
        allWindows().forEach((w) => w.classList.add("hidden"));
        document.getElementById(target)?.classList.remove("hidden");
      });
    });
    document.querySelectorAll(".close-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const target = btn.getAttribute("data-target");
        document.getElementById(target)?.classList.add("hidden");
        document.getElementById("clock")?.classList.remove("hidden");
      });
    });
  </script>
</div>
